<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
        xmlns:views="clr-namespace:Styloagent.App.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        xmlns:conv="clr-namespace:Styloagent.App.Converters"
        xmlns:cfg="clr-namespace:Styloagent.App.Config"
        xmlns:docs="clr-namespace:Styloagent.Core.Docs;assembly=Styloagent.Core"
        xmlns:terminal="clr-namespace:Styloagent.Terminal;assembly=Styloagent.Terminal"
        x:Class="Styloagent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Styloagent Cockpit"
        Icon="/icon.png"
        Width="1200"
        Height="800"
        Background="{DynamicResource CockpitBgBrush}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Alt+Right" Command="{Binding JumpToNextWaitingCommand}" />
  </Window.KeyBindings>

  <DockPanel>

    <!-- Top cockpit bar -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource CockpitAccentBrush}"
            Padding="8,4">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
          <Button Command="{Binding AddAgentCommand}" Padding="10,4" FontSize="13">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="Add" FontSize="16" />
              <TextBlock Text="Add agent" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding NewConsoleCommand}" Padding="10,4" FontSize="13"
                  ToolTip.Tip="Open a plain shell terminal (not an agent)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="›_" FontFamily="Menlo, Consolas, monospace" FontWeight="Bold"
                         VerticalAlignment="Center" />
              <TextBlock Text="New console" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Document search (Lucene autosuggest) — type to suggest, click a result to open it -->
        <AutoCompleteBox Grid.Column="1" Width="280" Margin="16,0" VerticalAlignment="Center"
                         Watermark="Search documents…"
                         FilterMode="None"
                         MinimumPrefixLength="1"
                         Text="{Binding SearchQuery}"
                         ItemsSource="{Binding SearchResults}"
                         SelectedItem="{Binding SelectedSearchResult}"
                         ValueMemberBinding="{Binding Title}">
          <AutoCompleteBox.ItemTemplate>
            <DataTemplate x:DataType="docs:DocSearchHit">
              <StackPanel Margin="2,1">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding RelativePath}" FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}" />
              </StackPanel>
            </DataTemplate>
          </AutoCompleteBox.ItemTemplate>
        </AutoCompleteBox>

        <!-- Centre: layout-mode segmented switch (Tabs / Tile / Auto-tile) -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <StackPanel.Styles>
            <Style Selector="ToggleButton">
              <Setter Property="Padding" Value="8,3" />
              <Setter Property="FontSize" Value="12" />
            </Style>
          </StackPanel.Styles>
          <ToggleButton IsChecked="{Binding IsTabsLayout, Mode=OneWay}" CornerRadius="4,0,0,4"
                        Command="{Binding SetLayoutModeCommand}" CommandParameter="Tabs" ToolTip.Tip="Tabs"
                        Content="Tabs" />
          <ToggleButton IsChecked="{Binding IsTileLayout, Mode=OneWay}" CornerRadius="0"
                        Command="{Binding SetLayoutModeCommand}" CommandParameter="Tile" ToolTip.Tip="Tile evenly"
                        Content="Tile" />
          <ToggleButton IsChecked="{Binding IsAutoTileLayout, Mode=OneWay}" CornerRadius="0,4,4,0"
                        Command="{Binding SetLayoutModeCommand}" CommandParameter="AutoTile"
                        ToolTip.Tip="Auto-tile: starter on top, agents tiled below"
                        Content="Auto-tile" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <!-- Screenshot button — only shown when UI automation is enabled in Settings -->
          <Button Padding="6,3" ToolTip.Tip="Capture a cockpit screenshot"
                  IsVisible="{Binding UiAutomationEnabled}"
                  Command="{Binding CaptureScreenshotCommand}">
            <ic:SymbolIcon Symbol="Camera" FontSize="15" />
          </Button>
          <ToggleButton x:Name="RosterToggleButton" IsChecked="{Binding IsRosterCollapsed}" Padding="6,3"
                        ToolTip.Tip="Collapse roster">
            <ic:SymbolIcon Symbol="PanelLeft" FontSize="15" />
          </ToggleButton>
          <ToggleButton x:Name="SidePanelToggleButton" IsChecked="{Binding IsSidePanelCollapsed}" Padding="6,3"
                        ToolTip.Tip="Collapse side panel">
            <ic:SymbolIcon Symbol="PanelRight" FontSize="15" />
          </ToggleButton>
          <Button x:Name="SettingsButton" Padding="6,3" ToolTip.Tip="Settings">
            <ic:SymbolIcon Symbol="Settings" FontSize="15" />
            <Button.Flyout>
              <Flyout>
                <StackPanel Width="210" Margin="4" Spacing="8">
                  <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource AccentBrush}" />
                  <ToggleSwitch Content="Light theme" IsChecked="{Binding IsLightTheme}" />
                  <TextBlock Text="Accent" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource AccentBrush}" />
                  <ComboBox ItemsSource="{Binding AvailableAccents}"
                            SelectedItem="{Binding SelectedAccent}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="cfg:AccentPreset">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Width="14" Height="14" CornerRadius="3" Background="{Binding Accent}" />
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Border Height="1" Background="{DynamicResource SubtleBorderBrush}" />
                  <TextBlock Text="Terminal theme (all agents)" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource AccentBrush}" />
                  <ComboBox ItemsSource="{Binding TerminalThemes}"
                            SelectedItem="{Binding GlobalTerminalTheme}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="terminal:TerminalTheme">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="Each agent's terminal can also be themed from its own toolbar."
                             FontSize="10" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
                  <Border Height="1" Background="{DynamicResource SubtleBorderBrush}" />
                  <TextBlock Text="Font sizes" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource AccentBrush}" />
                  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Terminal" FontSize="11"
                               VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Width="96" FontSize="11"
                                   Minimum="8" Maximum="32" Increment="1" FormatString="0"
                                   Value="{Binding TerminalFontSize}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Markdown" FontSize="11"
                               VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Width="96" FontSize="11"
                                   Minimum="8" Maximum="32" Increment="1" FormatString="0"
                                   Value="{Binding MarkdownFontSize}" />
                  </Grid>
                  <Border Height="1" Background="{DynamicResource SubtleBorderBrush}" />
                  <TextBlock Text="Automation" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource AccentBrush}" />
                  <ToggleSwitch Content="Enable UI automation" IsChecked="{Binding UiAutomationEnabled}" />
                  <TextBlock Text="Lets agents request cockpit screenshots via the MCP screenshot tool. Off by default; enabling broadcasts a bus notice and shows a shot button."
                             FontSize="10" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Fleet instruments strip (mission-control status bar) -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelHeaderBgBrush}" Padding="12,3">
      <StackPanel Orientation="Horizontal" Spacing="18">
        <StackPanel.Styles>
          <Style Selector="TextBlock"><Setter Property="FontSize" Value="11" /><Setter Property="VerticalAlignment" Value="Center" /></Style>
        </StackPanel.Styles>
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="◆" Foreground="{DynamicResource AccentBrush}" />
          <TextBlock Text="{Binding LiveAgentCount}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" />
          <TextBlock Text="agents" Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="▶" Foreground="#57A64A" />
          <TextBlock Text="{Binding WorkingCount}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" />
          <TextBlock Text="working" Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding WaitingCount, Converter={x:Static conv:CountToBoolConverter.Instance}}">
          <TextBlock Text="⚠" Foreground="{DynamicResource AttentionBrush}" />
          <TextBlock Text="{Binding WaitingCount}" Foreground="{DynamicResource AttentionBrush}" FontWeight="SemiBold" />
          <TextBlock Text="waiting" Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="▤" Foreground="{DynamicResource MutedTextBrush}" />
          <TextBlock Text="{Binding TimelineCount}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" />
          <TextBlock Text="ops" Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
        <TextBlock Text="{Binding FleetHudText}" Foreground="{DynamicResource MutedTextBrush}" />
      </StackPanel>
    </Border>

    <!-- Agents roster | selected terminal | signal bus. Roster/side columns collapse to 0. -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding IsRosterCollapsed, Converter={x:Static conv:CollapseToWidthConverter.Instance}, ConverterParameter=230}" />
        <ColumnDefinition Width="{Binding IsRosterCollapsed, Converter={x:Static conv:CollapseToWidthConverter.Instance}, ConverterParameter=4}" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="{Binding IsSidePanelCollapsed, Converter={x:Static conv:CollapseToWidthConverter.Instance}, ConverterParameter=4}" />
        <ColumnDefinition Width="{Binding IsSidePanelCollapsed, Converter={x:Static conv:CollapseToWidthConverter.Instance}, ConverterParameter=300}" />
      </Grid.ColumnDefinitions>

      <!-- Left column: the agent roster on top, the Signal Bus below it (more room here than the
           right panel). Draggable row splitter between them. -->
      <Grid Grid.Column="0" IsVisible="{Binding !IsRosterCollapsed}" RowDefinitions="*,5,1.3*">
        <views:AgentsView Grid.Row="0" />
        <GridSplitter Grid.Row="1" Background="#222" HorizontalAlignment="Stretch" ResizeDirection="Rows" />
        <views:BusView Grid.Row="2" DataContext="{Binding BusViewModel}" />
      </Grid>
      <GridSplitter Grid.Column="1" Background="#222" IsVisible="{Binding !IsRosterCollapsed}" />

      <!-- Centre: agent terminals as dockable documents (tabs, float, split).
           DataTemplates (AgentPaneViewModel→AgentPaneView) come from App.axaml. -->
      <dock:DockControl Grid.Column="2"
                        Layout="{Binding Layout}"
                        InitializeLayout="False"
                        InitializeFactory="False"
                        Background="{DynamicResource CockpitBgBrush}" />

      <GridSplitter Grid.Column="3" Background="#222" IsVisible="{Binding !IsSidePanelCollapsed}" />
      <TabControl Grid.Column="4" Background="{DynamicResource PanelBgBrush}" IsVisible="{Binding !IsSidePanelCollapsed}">
        <TabControl.Styles>
          <!-- Match the roster header typography so left/right titles read consistently. -->
          <Style Selector="TabItem">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#9D7FE0" />
          </Style>
        </TabControl.Styles>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="History" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="Timeline" VerticalAlignment="Center" />
            </StackPanel>
          </TabItem.Header>
          <views:TimelineView DataContext="{Binding Timeline}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="Document" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="Documents" VerticalAlignment="Center" />
            </StackPanel>
          </TabItem.Header>
          <views:DocLibraryView DataContext="{Binding DocLibrary}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="Warning" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="Issues" VerticalAlignment="Center" />
              <Border Background="#E5615A" CornerRadius="7" Padding="5,0" MinWidth="14"
                      VerticalAlignment="Center"
                      IsVisible="{Binding Issues.OpenCount, Converter={x:Static conv:CountToBoolConverter.Instance}}">
                <TextBlock Text="{Binding Issues.OpenCount}" FontSize="9" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" />
              </Border>
            </StackPanel>
          </TabItem.Header>
          <views:IssuesView DataContext="{Binding Issues}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="Flowchart" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="Git" VerticalAlignment="Center" />
            </StackPanel>
          </TabItem.Header>
          <TabControl Background="{DynamicResource PanelBgBrush}">
            <TabControl.Styles>
              <Style Selector="TabItem">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="#9D7FE0" />
              </Style>
            </TabControl.Styles>
            <TabItem Header="History">
              <views:GitGraphView DataContext="{Binding GitGraph}" />
            </TabItem>
            <TabItem Header="Changes">
              <views:ChangesView DataContext="{Binding Changes}" />
            </TabItem>
          </TabControl>
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ic:SymbolIcon Symbol="Globe" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="Router" VerticalAlignment="Center" />
            </StackPanel>
          </TabItem.Header>
          <views:RouterView DataContext="{Binding Router}" />
        </TabItem>
      </TabControl>

    </Grid>

  </DockPanel>

</Window>

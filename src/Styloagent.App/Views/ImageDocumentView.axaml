<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             x:Class="Styloagent.App.Views.ImageDocumentView"
             x:DataType="vm:ImageDocumentViewModel">
  <Grid RowDefinitions="Auto,*" Background="{DynamicResource PanelBgBrush}">
    <Border Background="{DynamicResource ChromeBgBrush}" Padding="10,6">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="−" Click="ZoomOut" ToolTip.Tip="Zoom out" />
        <Button Content="Fit" Click="FitImage" />
        <Button Content="+" Click="ZoomIn" ToolTip.Tip="Zoom in" />
        <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
        <TextBlock Text="Scroll to pan · Ctrl+wheel to zoom" VerticalAlignment="Center"
                   Foreground="{DynamicResource TertiaryTextBrush}" />
      </StackPanel>
    </Border>
    <ScrollViewer x:Name="ImageScroll" Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource PanelBgBrush}">
      <Border Padding="24" Background="{DynamicResource PanelBgBrush}">
        <Image x:Name="Preview" Source="{Binding Bitmap}" Stretch="None"
               RenderOptions.BitmapInterpolationMode="HighQuality" />
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>

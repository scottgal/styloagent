<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Styloagent.Terminal.TerminalControl"
             Background="#0C0C0C"
             Focusable="True"
             Cursor="Ibeam">

  <!-- A single monospace text block renders the VISIBLE rows (one control renders reliably; an
       ItemsControl-of-rows silently failed to materialize). It sits on a Canvas "Surface" sized to the
       WHOLE transcript so the scrollbar spans the full buffer, while the text block is virtualized: it
       holds only the rows intersecting the viewport (+ over-scan) and is positioned via Canvas.Top. That
       keeps every rebuild O(viewport) instead of O(transcript) — the fix for the layout-switch lockup. -->
  <!-- Padding is the terminal's gutter: a roomier LEFT gutter (12) so text isn't hard-flush against the
       pane edge, a slim right/top/bottom. This is the ScrollViewer content inset; PadX/PadY in the
       code-behind MUST mirror the horizontal/vertical totals or the grid col/row fit drifts. -->
  <ScrollViewer Name="ScrollArea"
                Background="#0C0C0C"
                Padding="12,4,6,4"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
    <Canvas Name="Surface" Background="#0C0C0C">
      <SelectableTextBlock Name="ScreenText"
                           Canvas.Left="0" Canvas.Top="0"
                           FontFamily="Menlo, Monaco, Cascadia Mono, Consolas, monospace"
                           FontSize="13"
                           LineHeight="16"
                           Foreground="#EDEDED"
                           Background="#0C0C0C"
                           TextWrapping="NoWrap" />
    </Canvas>
  </ScrollViewer>

</UserControl>

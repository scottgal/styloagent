<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
        xmlns:views="clr-namespace:Styloagent.App.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        x:Class="Styloagent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Styloagent Cockpit"
        Width="1200"
        Height="800"
        Background="#0C0C0C">

  <Window.KeyBindings>
    <KeyBinding Gesture="Alt+Right" Command="{Binding JumpToNextWaitingCommand}" />
  </Window.KeyBindings>

  <DockPanel>

    <!-- Top cockpit bar -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource CockpitAccentBrush}"
            Padding="8,4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Command="{Binding AddAgentCommand}" Padding="10,4" FontSize="13">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <ic:SymbolIcon Symbol="Add" FontSize="16" />
            <TextBlock Text="Add agent" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Agents roster | selected terminal | signal bus -->
    <Grid ColumnDefinitions="230,4,*,4,300">

      <views:AgentsView Grid.Column="0" />
      <GridSplitter Grid.Column="1" Background="#222" />

      <!-- Centre: agent terminals as dockable documents (tabs, float, split).
           DataTemplates (AgentPaneViewModel→AgentPaneView) come from App.axaml. -->
      <dock:DockControl Grid.Column="2"
                        Layout="{Binding Layout}"
                        InitializeLayout="False"
                        InitializeFactory="False"
                        Background="#0C0C0C" />

      <GridSplitter Grid.Column="3" Background="#222" />
      <TabControl Grid.Column="4" Background="#0D0D1A">
        <TabItem Header="Signal Bus">
          <views:BusView DataContext="{Binding BusViewModel}" />
        </TabItem>
        <TabItem Header="Documents">
          <views:DocLibraryView DataContext="{Binding DocLibrary}" />
        </TabItem>
      </TabControl>

    </Grid>

  </DockPanel>

</Window>

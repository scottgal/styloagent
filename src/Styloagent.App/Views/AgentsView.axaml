<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:conv="clr-namespace:Styloagent.App.Converters"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             x:Class="Styloagent.App.Views.AgentsView"
             x:DataType="vm:MainWindowViewModel">

  <UserControl.Styles>
    <Style Selector="Border.needsYou">
      <Setter Property="BorderBrush" Value="#E5A05A" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <!-- One roster row. Extracted to a resource so it can be rendered on a single control in a
         screenshot test (a headless ItemsControl doesn't materialize its item containers). -->
    <DataTemplate x:Key="AgentRowTemplate" DataType="vm:AgentPaneViewModel">
      <Button HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              Background="Transparent"
              BorderThickness="0"
              Padding="0"
              Margin="0,1,0,0"
              Command="{Binding DataContext.SelectPaneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
              CommandParameter="{Binding}">
        <Border Background="{Binding RowHighlightHex}"
                BorderBrush="{Binding SelectionBrushHex}"
                BorderThickness="1"
                CornerRadius="2"
                Classes.needsYou="{Binding NeedsYou}"
                Margin="{Binding Depth, Converter={x:Static conv:DepthToMarginConverter.Instance}}">
          <Grid ColumnDefinitions="4,*,Auto">
            <!-- Per-agent identity colour (same as its terminal accent) -->
            <Border Grid.Column="0" Background="{Binding BorderColorHex}" Width="4" />
            <StackPanel Grid.Column="1" Margin="8,6" Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                           Foreground="{Binding BorderColorHex}" />
                <!-- Hidden marker: the agent is off-screen but still running (Fix F) -->
                <TextBlock Text="hidden" FontSize="9" FontStyle="Italic" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}" IsVisible="{Binding IsHidden}" />
                <!-- "asked you" marker: this agent raised an ask_operator question (answer it in the top
                     bar). Cyan ❓, distinct from the amber ⚠ needs-you badge; separate from HookState. -->
                <Border Background="#123038" CornerRadius="3" Padding="4,0" VerticalAlignment="Center"
                        IsVisible="{Binding HasOperatorQuestion}" ToolTip.Tip="{Binding OperatorQuestionTooltip}">
                  <StackPanel Orientation="Horizontal" Spacing="3">
                    <TextBlock Text="❓" FontSize="9" Foreground="#4DB8C4" VerticalAlignment="Center" />
                    <TextBlock Text="asked you" FontSize="9" Foreground="#8FD8E2" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
                <!-- Throttled / rate-limited: Claude Code fires no hook when rate-limited, so the agent looks
                     alive but is stalled — amber ⏳ so it reads as throttled, not "working". Transient (not a
                     HookState); cleared when it makes forward progress. Tooltip = signature + since-time. -->
                <Border Background="#3A2E00" CornerRadius="3" Padding="4,0" VerticalAlignment="Center"
                        IsVisible="{Binding IsThrottled}" ToolTip.Tip="{Binding ThrottleTooltip}">
                  <StackPanel Orientation="Horizontal" Spacing="3">
                    <TextBlock Text="⏳" FontSize="9" VerticalAlignment="Center" />
                    <TextBlock Text="throttled" FontSize="9" Foreground="#E5A05A" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
              </StackPanel>
              <!-- Live hook state (§4.4): glyph + activity headline ("indexing repo"), coloured by state.
                   Hover shows the pending question when the agent needs you. -->
              <StackPanel Orientation="Horizontal" Spacing="5"
                          ToolTip.Tip="{Binding WaitingTooltip}">
                <TextBlock Text="{Binding HookStateGlyph}" FontSize="11"
                           Foreground="{Binding HookStateColorHex}" />
                <TextBlock Text="{Binding StatusHeadline}" FontSize="10"
                           Foreground="{Binding HookStateColorHex}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <!-- Relative "last output Ns" readout; hidden until the first hook event -->
              <TextBlock Text="{Binding LastOutputText}" FontSize="9"
                         Foreground="{DynamicResource MutedTextBrush}"
                         IsVisible="{Binding HasActivityMeta}" />
              <!-- Runtime selection resolved for this job: agent · model · effort. -->
              <TextBlock Text="{Binding AgentSelectionText}" FontSize="9"
                         Foreground="{DynamicResource MutedTextBrush}" />
              <!-- Token / context readout ("83k · 22%") from the agent's transcript -->
              <TextBlock Text="{Binding UsageText}" FontSize="9"
                         Foreground="{DynamicResource MutedTextBrush}"
                         IsVisible="{Binding HasUsage}" />
            </StackPanel>
            <!-- Quick Approve + per-agent management menu + identity dot (amber when the agent needs you) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="0,0,8,0">
              <!-- One-click: send "Yes" to a waiting agent's permission prompt (hover = the question) -->
              <Button Content="Approve" FontSize="9" Padding="6,1" VerticalAlignment="Center"
                      Background="#5A4A00" Foreground="#FFE9A8"
                      IsVisible="{Binding NeedsYou}"
                      Command="{Binding Host.ApprovePermissionCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="{Binding WaitingTooltip}" />
              <!-- Manage: every pane/tab action in one menu (Fix: tabs weren't functional).
                   Flyout items bind via Host (the popup is outside the visual tree, so ancestor bindings fail). -->
              <Button Content="⋯" FontSize="13" Padding="6,0" VerticalAlignment="Center"
                      ToolTip.Tip="Manage this agent">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuItem Header="Approve prompt"
                              IsEnabled="{Binding NeedsYou}"
                              Command="{Binding Host.ApprovePermissionCommand}"
                              CommandParameter="{Binding}" />
                    <Separator />
                    <MenuItem Header="Hide pane" IsVisible="{Binding !IsHidden}"
                              Command="{Binding Host.HideAgentCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="Show pane" IsVisible="{Binding IsHidden}"
                              Command="{Binding Host.ShowAgentCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="Dehydrate (checkpoint + park)" Command="{Binding DehydrateCommand}" />
                    <MenuItem Header="Rehydrate" Command="{Binding RehydrateCommand}" />
                    <Separator />
                    <MenuItem Header="Kill"
                              Command="{Binding Host.KillAgentCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="Force-kill (SIGKILL)"
                              Command="{Binding Host.ForceKillAgentCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="Remove from roster"
                              Command="{Binding Host.RemoveAgentCommand}"
                              CommandParameter="{Binding}" />
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
              <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding HookStateColorHex}" />
            </StackPanel>
          </Grid>
        </Border>
      </Button>
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,6">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <ic:SymbolIcon Symbol="People" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
            <StackPanel>
              <TextBlock Text="Agents" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource AccentBrush}" LetterSpacing="1" />
              <TextBlock Text="{Binding FleetHudText}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                        IsVisible="{Binding WaitingCount, Converter={x:Static conv:CountToBoolConverter.Instance}}">
              <TextBlock Text="{Binding AttentionHudText}" FontSize="10" Foreground="{DynamicResource AttentionBrush}" VerticalAlignment="Center" />
              <Button Content="Jump ⌥→" FontSize="10" Padding="6,1" Command="{Binding JumpToNextWaitingCommand}" />
            </StackPanel>
            <ToggleButton VerticalAlignment="Center" FontSize="10" Padding="6,2"
                          IsChecked="{Binding FleetPaused, Mode=OneWay}" Command="{Binding PauseFleetCommand}"
                          Content="⏸ Pause" />
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- PROPOSED subsystems: written by the overview agent; click Spawn to promote to live.
               Collapsed into an accordion by default (Fix 0) so the proposed list keeps a minimal
               vertical footprint and doesn't dominate the roster — the operator expands it to spawn.
               The whole Expander hides when there are no proposals. -->
          <Expander IsExpanded="False"
                    HorizontalAlignment="Stretch"
                    Padding="0"
                    Margin="0,0,0,1"
                    IsVisible="{Binding ProposedTeam.Proposals.Count, Converter={x:Static conv:CountToBoolConverter.Instance}}">
            <Expander.Header>
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <TextBlock Text="PROPOSED" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource AttentionBrush}" LetterSpacing="1"
                           VerticalAlignment="Center" />
                <!-- Count badge so the operator sees how many proposals are waiting without expanding. -->
                <Border Background="#3A2020" CornerRadius="7" Padding="5,0" MinWidth="16" VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProposedTeam.Proposals.Count}" FontSize="10"
                             Foreground="{DynamicResource AttentionBrush}" HorizontalAlignment="Center" />
                </Border>
                <Button Content="Spawn all" FontSize="9" Padding="5,0" Margin="4,0,0,0"
                        Command="{Binding ProposedTeam.SpawnAllCommand}" />
              </StackPanel>
            </Expander.Header>

            <ItemsControl ItemsSource="{Binding ProposedTeam.Proposals}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:ProposedAgentItem">
                    <Border Background="{DynamicResource RowBgBrush}" Margin="0,1,0,0">
                      <Grid ColumnDefinitions="4,*,Auto">
                        <Border Grid.Column="0" Background="{Binding ColorHex}" Width="4" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="7,2" Spacing="6">
                          <TextBlock Text="{Binding Prefix}" FontWeight="SemiBold" FontSize="11" Foreground="{Binding ColorHex}" />
                          <TextBlock Text="{Binding Responsibility}" FontSize="9" Foreground="#8888AA" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding RejectionMessage}" FontSize="9" Foreground="#E5736B"
                                     IsVisible="{Binding RejectionMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Spawn" FontSize="9" Padding="5,0" Margin="0,0,5,0" VerticalAlignment="Center"
                                Command="{Binding DataContext.ProposedTeam.SpawnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Agent}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
          </Expander>

          <!-- Live roster, grouped by repo so each repo's fleet roots at ITS OWN overview (BUG 3). The
               repo header shows only in a multi-repo workspace; a single repo renders as one header-less
               group — visually identical to the old flat list. -->
          <ItemsControl ItemsSource="{Binding RosterGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:RosterRepoGroup">
                <StackPanel>
                  <Border IsVisible="{Binding ShowHeader}"
                          Background="{DynamicResource PanelHeaderBgBrush}"
                          Padding="8,3" Margin="0,4,0,1" CornerRadius="2">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <Ellipse Width="7" Height="7" Fill="{Binding ColorHex}" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding RepoName}" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{Binding ColorHex}" LetterSpacing="1" VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <ItemsControl ItemsSource="{Binding Agents}"
                                ItemTemplate="{StaticResource AgentRowTemplate}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             x:Class="Styloagent.App.Views.DocLibraryView"
             x:DataType="vm:DocLibraryViewModel">

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,6">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Content="System Map" FontSize="10" Padding="6,1"
                  Command="{Binding ShowSystemMapCommand}" />
          <Button Content="Bus Sequence" FontSize="10" Padding="6,1"
                  Command="{Binding ShowBusSequenceCommand}" />
          <Button Content="Architecture" FontSize="10" Padding="6,1"
                  Command="{Binding ShowArchitectureCommand}" />
        </StackPanel>
      </Border>

      <!-- File/folder tree of the docs. Folders expand/collapse; files are buttons that open. -->
      <TreeView Grid.Row="1"
                x:Name="DocsTree"
                ItemsSource="{Binding Roots}"
                Background="Transparent">
        <TreeView.Styles>
          <!-- Bind each container's expansion to the node so folders honour DocNode.IsExpanded. -->
          <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
          </Style>
        </TreeView.Styles>
        <TreeView.ItemTemplate>
          <TreeDataTemplate x:DataType="vm:DocLibraryViewModel+DocNode" ItemsSource="{Binding Children}">
            <Panel>
              <!-- Folder row -->
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1"
                          IsVisible="{Binding IsFolder}">
                <ic:SymbolIcon Symbol="Folder" FontSize="14" VerticalAlignment="Center"
                               Foreground="#9D7FE0" />
                <TextBlock Text="{Binding Name}" FontSize="11.5" VerticalAlignment="Center"
                           Foreground="#CCCCDD" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <!-- File row: a borderless button that opens the doc on click. -->
              <Button IsVisible="{Binding !IsFolder}"
                      Background="Transparent" BorderThickness="0" Padding="0,1"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Command="{Binding $parent[TreeView].((vm:DocLibraryViewModel)DataContext).OpenDocCommand}"
                      CommandParameter="{Binding Entry}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <ic:SymbolIcon Symbol="Document" FontSize="14" VerticalAlignment="Center"
                                 Foreground="#8899BB" />
                  <TextBlock Text="{Binding Name}" FontSize="11.5" VerticalAlignment="Center"
                             Foreground="#CCCCDD" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Button>
            </Panel>
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>

    </Grid>
  </Border>

</UserControl>

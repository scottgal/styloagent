<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <!-- Structural chrome colours that invert between dark and light. -->
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="CockpitBgBrush" Color="#0C0C0C"/>
      <SolidColorBrush x:Key="PanelBgBrush" Color="#0D0D1A"/>
      <SolidColorBrush x:Key="PanelHeaderBgBrush" Color="#1A1A2E"/>
      <SolidColorBrush x:Key="RowBgBrush" Color="#111122"/>
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0E0FF"/>
      <SolidColorBrush x:Key="MutedTextBrush" Color="#7A7AA0"/>
      <SolidColorBrush x:Key="SubtleBorderBrush" Color="#222226"/>
      <SolidColorBrush x:Key="DiffAddedBgBrush" Color="#1E3A24"/>
      <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="#3A1E1E"/>
      <SolidColorBrush x:Key="DiffHeaderBgBrush" Color="#2A2A3A"/>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="CockpitBgBrush" Color="#F1F1F5"/>
      <SolidColorBrush x:Key="PanelBgBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="PanelHeaderBgBrush" Color="#E7E7EF"/>
      <SolidColorBrush x:Key="RowBgBrush" Color="#EFEFF5"/>
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A2E"/>
      <SolidColorBrush x:Key="MutedTextBrush" Color="#5C5C78"/>
      <SolidColorBrush x:Key="SubtleBorderBrush" Color="#D6D6E0"/>
      <SolidColorBrush x:Key="DiffAddedBgBrush" Color="#D6F0DD"/>
      <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="#F5D6D6"/>
      <SolidColorBrush x:Key="DiffHeaderBgBrush" Color="#E6E6EE"/>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Accent brushes — overridden at startup from the saved accent preset (AccentPalette / ThemeApplier).
       These defaults match the "Blue" preset so the app is never the old purple, even before prefs load. -->
  <SolidColorBrush x:Key="CockpitAccentBrush" Color="#1E4F9E"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
  <SolidColorBrush x:Key="AttentionBrush" Color="#E5A05A"/>
</ResourceDictionary>

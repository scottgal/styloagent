<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
        xmlns:views="clr-namespace:Styloagent.App.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        x:Class="Styloagent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Styloagent Cockpit"
        Width="1200"
        Height="800">

  <DockPanel>

    <!-- Top cockpit bar -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource CockpitAccentBrush}"
            Padding="8,4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Command="{Binding AddAgentCommand}"
                Padding="10,4"
                FontSize="13">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <ic:SymbolIcon Symbol="Add" FontSize="16" />
            <TextBlock Text="Add agent" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <dock:DockControl x:Name="DockControl"
                      Layout="{Binding Layout}"
                      InitializeLayout="False"
                      InitializeFactory="False">
      <dock:DockControl.DataTemplates>
        <DataTemplate DataType="vm:AgentPaneViewModel">
          <views:AgentPaneView />
        </DataTemplate>
        <DataTemplate DataType="vm:BusViewModel">
          <views:BusView />
        </DataTemplate>
      </dock:DockControl.DataTemplates>
    </dock:DockControl>

  </DockPanel>

</Window>

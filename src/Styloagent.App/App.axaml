<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:views="clr-namespace:Styloagent.App.Views"
             xmlns:dockControls="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             x:Class="Styloagent.App.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Styloagent.App/Themes/ThemeTokens.axaml" />
        <!-- LiveMarkdown.Avalonia default resources (heading sizes, code/quote colours, etc.). -->
        <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml" />

    <!-- Per-agent identity colour on the centre document tabs (shared with the UI test harness). -->
    <StyleInclude Source="avares://Styloagent.App/Themes/DockTabStyles.axaml" />

    <!-- Markdown typography (heading sizes/weights, lists, code blocks, quotes). Without this,
         LiveMarkdown renders headings as plain body text. -->
    <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml" />
  </Application.Styles>

  <Application.DataTemplates>
    <DataTemplate DataType="vm:AgentPaneViewModel">
      <views:AgentPaneView />
    </DataTemplate>
    <DataTemplate DataType="vm:ConsolePaneViewModel">
      <views:ConsolePaneView />
    </DataTemplate>
    <DataTemplate DataType="vm:BusViewModel">
      <views:BusView />
    </DataTemplate>
    <DataTemplate DataType="vm:DiagramDocumentViewModel">
      <views:DiagramDocumentView />
    </DataTemplate>
    <DataTemplate DataType="vm:MarkdownDocumentViewModel">
      <views:MarkdownDocumentView />
    </DataTemplate>
    <DataTemplate DataType="vm:SourceDocumentViewModel">
      <views:SourceDocumentView />
    </DataTemplate>
    <DataTemplate DataType="vm:DiffDocumentViewModel">
      <views:DiffDocumentView />
    </DataTemplate>
  </Application.DataTemplates>

</Application>

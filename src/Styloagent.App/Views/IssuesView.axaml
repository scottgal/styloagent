<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:conv="clr-namespace:Styloagent.App.Converters"
             x:Class="Styloagent.App.Views.IssuesView"
             x:DataType="vm:IssuesViewModel">

  <UserControl.Resources>
    <conv:SeverityColorConverter x:Key="SeverityColor" />
  </UserControl.Resources>

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,6">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="Issues raised by the fleet" FontSize="11"
                     Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="Refresh" FontSize="10" Padding="6,1"
                  Command="{Binding RefreshCommand}" />
        </Grid>
      </Border>

      <!-- Empty state -->
      <TextBlock Grid.Row="1" IsVisible="{Binding !HasIssues}"
                 Text="No issues yet. Agents file them with report_issue over MCP."
                 FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                 TextWrapping="Wrap" Padding="12" />

      <ScrollViewer Grid.Row="1" IsVisible="{Binding HasIssues}"
                    HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Issues}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:IssueItem">
              <Border Padding="10,7" Margin="0,1,0,0" Background="{DynamicResource RowBgBrush}">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Severity dot -->
                    <Ellipse Grid.Column="0" Width="8" Height="8"
                             VerticalAlignment="Top" Margin="0,3,8,0"
                             Fill="{Binding Severity, Converter={StaticResource SeverityColor}}" />
                    <!-- Clickable header: click a title to expand its detail (like a bus thread) -->
                    <Button Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                            Command="{Binding ToggleExpandCommand}"
                            ToolTip.Tip="Click to expand / collapse">
                      <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                          <TextBlock Text="{Binding Reporter}" FontSize="10"
                                     Foreground="{DynamicResource MutedTextBrush}" />
                          <TextBlock Text="{Binding Severity}" FontSize="10"
                                     Foreground="{DynamicResource MutedTextBrush}" />
                          <TextBlock Text="{Binding Status}" FontSize="10"
                                     Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>
                      </StackPanel>
                    </Button>
                    <!-- Resolve: marks the issue closed and clears it from the active list -->
                    <Button Grid.Column="2" Content="Resolve" FontSize="10" Padding="6,1" VerticalAlignment="Top"
                            Command="{Binding DataContext.ResolveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Mark resolved and clear from the list" />
                  </Grid>
                  <!-- Expanded detail (full body), revealed on click -->
                  <TextBlock Text="{Binding Detail}" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             IsVisible="{Binding IsExpanded}" Margin="16,2,0,2" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>

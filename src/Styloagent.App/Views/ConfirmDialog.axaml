<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Styloagent.App.Views.ConfirmDialog"
        Title="Confirm"
        Width="400" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource CockpitBgBrush}">
  <StackPanel Margin="18" Spacing="16">
    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
               Foreground="{DynamicResource PrimaryTextBrush}" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="CancelButton" Content="Cancel" Padding="16,4" />
      <Button x:Name="ConfirmButton" Content="Shut down" Padding="16,4" Foreground="#E5736B" />
    </StackPanel>
  </StackPanel>
</Window>

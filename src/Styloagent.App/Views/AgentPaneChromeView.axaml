<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             x:Class="Styloagent.App.Views.AgentPaneChromeView"
             x:DataType="vm:AgentPaneViewModel"
             IsVisible="False" Height="0">
  <!-- Gutted (operator fix): the agent name, the ⋯ actions menu, the terminal zoom and the theme picker
       moved ONTO the dock tab header (DockTabStyles.axaml → StyloagentTabHeaderTemplate) so the pane no
       longer needs a duplicate header row — the tab already shows the name + close. This control now
       renders nothing and collapses to zero height; session- removes its Grid.Row=0 host in
       AgentPaneView.axaml so the terminal reclaims the space. Kept as an (empty) type only so that file
       keeps compiling until session- lands the host removal. -->
</UserControl>

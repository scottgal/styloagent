<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             x:Class="Styloagent.App.Views.BusView"
             x:DataType="vm:BusViewModel">

  <UserControl.Resources>
    <!-- Shared message-row template, used by both Current and Archive lists. -->
    <DataTemplate x:Key="MsgTemplate" DataType="vm:BusMessageItem">
      <Border Margin="0,1,0,0" Background="#111122" BoxShadow="0 1 3 0 #33000000">
        <Grid ColumnDefinitions="4,*">
          <Border Grid.Column="0" Background="{Binding ColorHex}" Width="4" />
          <StackPanel Grid.Column="1" Margin="8,5,8,5" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding RoutingPrefix}" FontWeight="Bold" FontSize="11"
                         Foreground="{Binding ColorHex}" />
              <TextBlock Text="{Binding Slug}" FontSize="11" Foreground="#CCCCDD"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#2A2A44" CornerRadius="3" Padding="4,1">
                <TextBlock FontSize="9" Foreground="#8888AA">
                  <Run Text="{Binding Kind}" /><Run Text=" · " /><Run Text="{Binding State}" />
                </TextBlock>
              </Border>
              <TextBlock Text="{Binding RelativeTime}" FontSize="9" Foreground="#555566"
                         VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="#0D0D1A" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="#1A1A2E" Padding="8,6">
        <TextBlock Text="Signal Bus" FontWeight="Bold" FontSize="13"
                   Foreground="#9D7FE0" LetterSpacing="1" />
      </Border>

      <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- Current -->
          <Border Background="#15152A" Padding="8,4">
            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7A7AA0" LetterSpacing="1">
              <Run Text="CURRENT" /><Run Text=" · " /><Run Text="{Binding CurrentMessages.Count}" />
            </TextBlock>
          </Border>
          <ItemsControl ItemsSource="{Binding CurrentMessages}" ItemTemplate="{StaticResource MsgTemplate}" />

          <!-- Archive -->
          <Border Background="#15152A" Padding="8,4" Margin="0,6,0,0">
            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#55556E" LetterSpacing="1">
              <Run Text="ARCHIVE" /><Run Text=" · " /><Run Text="{Binding ArchivedMessages.Count}" />
            </TextBlock>
          </Border>
          <ItemsControl ItemsSource="{Binding ArchivedMessages}" ItemTemplate="{StaticResource MsgTemplate}" />

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>

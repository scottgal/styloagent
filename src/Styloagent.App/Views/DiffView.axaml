<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:conv="clr-namespace:Styloagent.App.Converters"
             xmlns:git="clr-namespace:Styloagent.Core.Git;assembly=Styloagent.Core"
             x:Class="Styloagent.App.Views.DiffView"
             x:DataType="vm:DiffViewModel">

  <UserControl.Resources>
    <conv:DiffLineKindBrushConverter x:Key="DiffLineKindBrush" />
  </UserControl.Resources>

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid>

      <!-- Empty state -->
      <TextBlock IsVisible="{Binding !HasDiff}"
                 Text="Select a file to see its diff"
                 FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                 TextWrapping="Wrap" Padding="12" />

      <ScrollViewer IsVisible="{Binding HasDiff}"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding File.Lines}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="git:DiffLine">
              <Grid ColumnDefinitions="40,40,*"
                    Background="{Binding Kind, Converter={StaticResource DiffLineKindBrush}}">

                <!-- Old line number -->
                <TextBlock Grid.Column="0"
                           Text="{Binding OldLine}"
                           IsVisible="{Binding OldLine, Converter={x:Static conv:CountToBoolConverter.Instance}}"
                           FontFamily="Cascadia Mono,Consolas,monospace"
                           FontSize="11"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextAlignment="Right"
                           Padding="0,1,4,1" />

                <!-- New line number -->
                <TextBlock Grid.Column="1"
                           Text="{Binding NewLine}"
                           IsVisible="{Binding NewLine, Converter={x:Static conv:CountToBoolConverter.Instance}}"
                           FontFamily="Cascadia Mono,Consolas,monospace"
                           FontSize="11"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextAlignment="Right"
                           Padding="0,1,4,1" />

                <!-- Line content -->
                <TextBlock Grid.Column="2"
                           Text="{Binding Content}"
                           FontFamily="Cascadia Mono,Consolas,monospace"
                           FontSize="11"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           TextWrapping="NoWrap"
                           Padding="4,1,4,1" />

              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>

<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Styloagent.App.Converters"
        xmlns:terminal="clr-namespace:Styloagent.Terminal;assembly=Styloagent.Terminal"
        xmlns:dockControls="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia">
  <!-- Per-agent identity colour on the centre document tabs (shared with the UI test harness).
       INACTIVE tabs are dim: transparent fill, agent-colour caption, thin agent-colour underline.
       The ACTIVE tab is FILLED with the agent's identity colour (not Dock's default blue), with a
       luminance-picked caption (black on a bright colour, white on a dark one) so it stays legible. -->
  <Style Selector="dockControls|DocumentTabStripItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground"
            Value="{Binding BorderColorHex, FallbackValue=#C8C8E0, TargetNullValue=#C8C8E0}" />
    <Setter Property="BorderBrush"
            Value="{Binding BorderColorHex, FallbackValue=Transparent, TargetNullValue=Transparent}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>
  <Style Selector="dockControls|DocumentTabStripItem:selected">
    <Setter Property="Background"
            Value="{Binding BorderColorHex, FallbackValue=#3B82F6, TargetNullValue=#3B82F6}" />
    <Setter Property="Foreground"
            Value="{Binding TabSelectedForegroundHex, FallbackValue=#FFFFFF, TargetNullValue=#FFFFFF}" />
    <Setter Property="BorderBrush"
            Value="{Binding BorderColorHex, FallbackValue=#3B82F6, TargetNullValue=#3B82F6}" />
  </Style>
  <!-- Keep the fill on hover/pointerover of the selected tab too (Dock would otherwise re-tint it). -->
  <Style Selector="dockControls|DocumentTabStripItem:selected:pointerover">
    <Setter Property="Background"
            Value="{Binding BorderColorHex, FallbackValue=#3B82F6, TargetNullValue=#3B82F6}" />
    <Setter Property="Foreground"
            Value="{Binding TabSelectedForegroundHex, FallbackValue=#FFFFFF, TargetNullValue=#FFFFFF}" />
  </Style>

  <!-- DocumentControl content template. This is Dock 11.3.12.1's stock "cached content" template
       VERBATIM (all DockProperties drop-areas / dock-targets / adorners preserved, so drag-docking,
       splitting and floating keep working) with EXACTLY ONE change: each document host's visibility.
       Stock binds it to `((IDock)Owner).ActiveDockable`, which does not update on tab switch in this
       version, so every agent's live XTerm terminal stays visible and they stack on one surface. We
       instead compare the item to the DocumentControl's DataContext.ActiveDockable (which DOES notify)
       via our own ReferenceEqualsMultiConverter — so all terminals stay alive but only the active one
       renders. -->
  <Styles.Resources>
    <!-- Document-tab header: the dockable's title PLUS, for AGENT tabs only, the per-pane ⋯ actions menu
         (operator fix: kill the redundant AgentPaneChromeView header row — the tab already shows the name,
         so name+actions+zoom belong ON the tab). Shared across every document type, so it uses reflection
         bindings (no x:DataType): the title binds on any dockable; the agent-only menu is gated by
         IsAgentPaneConverter and its command bindings simply no-op on non-agent tabs (and its flyout is
         never built there). Fleet-level commands go via Host (MainWindowViewModel), same split as before. -->
    <DataTemplate x:Key="StyloagentTabHeaderTemplate">
      <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Stretch">
        <!-- Repo-identity band: a left-edge stripe coloured by the agent's repo (its overview hue, matching
             the roster grouping colour) so mixed-repo tabs are distinguishable. Shown only in a multi-repo
             workspace (RepoBandColorHex is null otherwise). Non-agent tabs never set it. -->
        <Border Width="3" CornerRadius="1.5" Margin="0,3,5,3" VerticalAlignment="Stretch"
                Background="{Binding RepoBandColorHex}"
                ToolTip.Tip="{Binding RepoBandTooltip}"
                IsVisible="{Binding RepoBandColorHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        <Button Content="⋯" FontSize="13" FontWeight="Bold" Padding="5,0" MinWidth="0" MinHeight="0"
                Margin="4,0,0,0" Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                IsVisible="{Binding Converter={x:Static conv:IsAgentPaneConverter.Instance}}"
                ToolTip.Tip="Agent actions">
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Header="Spawn" Command="{Binding SpawnCommand}" />
              <MenuItem Header="Dehydrate (checkpoint + park)" Command="{Binding DehydrateCommand}" />
              <MenuItem Header="Rehydrate" Command="{Binding RehydrateCommand}" />
              <MenuItem Header="Rename" Command="{Binding RenameCommand}" CommandParameter="New Name" />
              <Separator />
              <MenuItem Header="Log (this agent)" Command="{Binding OpenLogCommand}" />
              <Separator />
              <!-- Terminal zoom, moved off the old header into the menu (operator). StaysOpenOnClick keeps
                   the slider usable; two-way to the VM ZoomLevel relay session- binds the terminal to. -->
              <MenuItem StaysOpenOnClick="True" ToolTip.Tip="Terminal zoom">
                <MenuItem.Header>
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Zoom" VerticalAlignment="Center" />
                    <Slider Width="110" Height="18" MinHeight="0" VerticalAlignment="Center"
                            Minimum="0.5" Maximum="3.0" SmallChange="0.1" LargeChange="0.5" TickFrequency="0.1"
                            Value="{Binding ZoomLevel, Mode=TwoWay}" />
                    <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" MinWidth="34"
                               VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" />
                  </StackPanel>
                </MenuItem.Header>
              </MenuItem>
              <!-- Terminal theme picker (unchanged from the old header menu). -->
              <MenuItem StaysOpenOnClick="True" ToolTip.Tip="Terminal theme">
                <MenuItem.Header>
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Theme" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding TerminalThemes}"
                              SelectedItem="{Binding SelectedTerminalTheme}"
                              MinWidth="120" FontSize="11" VerticalAlignment="Center">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="terminal:TerminalTheme">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </MenuItem.Header>
              </MenuItem>
              <Separator />
              <MenuItem Header="Approve prompt" IsEnabled="{Binding NeedsYou}"
                        Command="{Binding Host.ApprovePermissionCommand}" CommandParameter="{Binding}" />
              <MenuItem Header="Hide pane" IsVisible="{Binding !IsHidden}"
                        Command="{Binding Host.HideAgentCommand}" CommandParameter="{Binding}" />
              <MenuItem Header="Show pane" IsVisible="{Binding IsHidden}"
                        Command="{Binding Host.ShowAgentCommand}" CommandParameter="{Binding}" />
              <Separator />
              <MenuItem Header="Kill" Command="{Binding Host.KillAgentCommand}" CommandParameter="{Binding}" />
              <MenuItem Header="Force-kill (SIGKILL)" Command="{Binding Host.ForceKillAgentCommand}"
                        CommandParameter="{Binding}" />
              <MenuItem Header="Remove from roster" Command="{Binding Host.RemoveAgentCommand}"
                        CommandParameter="{Binding}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </StackPanel>
    </DataTemplate>

    <ControlTemplate x:Key="StyloagentDocumentContentTemplate" TargetType="DocumentControl">
      <DockPanel x:Name="PART_DockPanel"
                 DockProperties.IsDropArea="True"
                 DockProperties.IsDockTarget="True"
                 DockProperties.ShowDockIndicatorOnly="{DynamicResource DockDocumentControlShowDockIndicatorOnly}"
                 DockProperties.IndicatorDockOperation="{DynamicResource DockDocumentControlIndicatorDockOperation}"
                 VerticalSpacing="{DynamicResource DockDocumentControlVerticalSpacing}"
                 Background="Transparent"
                 ZIndex="1">
        <DocumentTabStrip x:Name="PART_TabStrip"
                          ItemsSource="{Binding VisibleDockables}"
                          SelectedItem="{Binding ActiveDockable, Mode=TwoWay}"
                          CanCreateItem="{Binding CanCreateDocument}"
                          IconTemplate="{TemplateBinding IconTemplate}"
                          HeaderTemplate="{TemplateBinding HeaderTemplate}"
                          ModifiedTemplate="{TemplateBinding ModifiedTemplate}"
                          CloseTemplate="{TemplateBinding CloseTemplate}"
                          CloseButtonTheme="{TemplateBinding CloseButtonTheme}"
                          IsActive="{TemplateBinding IsActive}"
                          Orientation="{Binding TabsLayout, Converter={x:Static DocumentTabOrientationConverter.Instance}}"
                          DockPanel.Dock="{Binding TabsLayout, Converter={x:Static DocumentTabDockConverter.Instance}}"
                          DockProperties.IsDropArea="True"
                          DockProperties.DockAdornerHost="{Binding #PART_DockPanel}">
          <DocumentTabStrip.Styles>
            <Style Selector="DocumentTabStripItem">
              <Setter Property="IsActive" Value="{Binding $parent[DocumentTabStrip].IsActive}" />
            </Style>
          </DocumentTabStrip.Styles>
        </DocumentTabStrip>
        <Panel x:Name="PART_DocumentSeperatorHost" IsVisible="{Binding #PART_TabStrip.IsVisible}">
          <Panel x:Name="PART_DocumentSeperator"
                 IsVisible="{DynamicResource DockDocumentTabStripSeparatorVisible}" />
        </Panel>
        <Border x:Name="PART_Border">
          <Grid>
            <ItemsControl x:Name="PART_CachedContentHost"
                          ItemsSource="{Binding VisibleDockables}"
                          IsVisible="{Binding $parent[DocumentControl].HasVisibleDockables}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Grid />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <DockableControl TrackingMode="Visible">
                    <DockableControl.IsVisible>
                      <MultiBinding Converter="{x:Static conv:ReferenceEqualsMultiConverter.Instance}">
                        <Binding />
                        <Binding Path="DataContext.ActiveDockable"
                                 RelativeSource="{RelativeSource AncestorType=DocumentControl}" />
                      </MultiBinding>
                    </DockableControl.IsVisible>
                    <ContentControl x:Name="PART_CachedContentPresenter"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Content="{Binding}" />
                  </DockableControl>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ContentControl x:Name="PART_EmptyContentHost"
                            Content="{Binding EmptyContent}"
                            ContentTemplate="{Binding $parent[DocumentControl].EmptyContentTemplate}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            IsVisible="{Binding !$parent[DocumentControl].HasVisibleDockables}" />
          </Grid>
        </Border>
      </DockPanel>
    </ControlTemplate>
  </Styles.Resources>

  <Style Selector="dockControls|DocumentControl">
    <Setter Property="Template" Value="{StaticResource StyloagentDocumentContentTemplate}" />
    <!-- Tab caption + agent ⋯ menu (name+actions+zoom live on the tab now, not a separate header row). -->
    <Setter Property="HeaderTemplate" Value="{StaticResource StyloagentTabHeaderTemplate}" />
  </Style>
</Styles>

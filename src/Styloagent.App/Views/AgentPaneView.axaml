<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:terminal="clr-namespace:Styloagent.Terminal;assembly=Styloagent.Terminal"
             xmlns:views="clr-namespace:Styloagent.App.Views"
             x:Class="Styloagent.App.Views.AgentPaneView"
             x:DataType="vm:AgentPaneViewModel">

  <Border Name="PaneBorder"
          BorderBrush="{Binding BorderColorHex}"
          BorderThickness="1.5"
          CornerRadius="4"
          BoxShadow="0 2 8 0 #44000000">
    <Grid ColumnDefinitions="3,*">

      <!-- Left accent stripe -->
      <Border Name="AccentStripe"
              Grid.Column="0"
              Background="{Binding BorderColorHex}"
              CornerRadius="4,0,0,4" />

      <Grid Grid.Column="1" RowDefinitions="Auto,*">

        <!-- Pane header chrome (cockpit-owned: ⋯ actions menu + zoom slider + theme picker) -->
        <views:AgentPaneChromeView Grid.Row="0" />

        <!-- Terminal area -->
        <terminal:TerminalControl Name="Terminal"
                                  Grid.Row="1"
                                  ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}" />

      </Grid>
    </Grid>
  </Border>

</UserControl>

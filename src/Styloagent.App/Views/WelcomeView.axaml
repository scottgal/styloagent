<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:conv="clr-namespace:Styloagent.App.Converters"
             x:Class="Styloagent.App.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">
  <Border Background="{DynamicResource CockpitBgBrush}" Padding="28">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="14" VerticalAlignment="Top" HorizontalAlignment="Center" MaxWidth="440">
      <TextBlock FontSize="24">
        <Run Text="stylo" FontWeight="Bold" FontStyle="Italic" Foreground="#DDDDDD" /><Run Text="agent" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
      </TextBlock>

      <!-- New system: scope from a one-line goal; the architect agent figures out the shape. -->
      <TextBlock Text="New system" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                 LetterSpacing="1" Margin="0,6,0,0" />
      <TextBox Watermark="Build a system like X which does Y…"
               Text="{Binding NewSystemDescription}"
               AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64" />
      <Button Content="Create new system →" Command="{Binding NewSystemCommand}"
              Padding="14,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />

      <Border Background="#151528" BorderBrush="#2B2B45" BorderThickness="1" CornerRadius="6" Padding="4">
        <Grid ColumnDefinitions="*,*">
          <ToggleButton x:Name="ClaudeFirstToggle" Grid.Column="0" Content="Claude first"
                        IsChecked="{Binding IsClaudeFirst, Mode=OneWay}"
                        Command="{Binding SetRuntimeModeCommand}" CommandParameter="Claude"
                        Padding="10,6" HorizontalContentAlignment="Center" />
          <ToggleButton x:Name="CodexFirstToggle" Grid.Column="1" Content="Codex first"
                        IsChecked="{Binding IsCodexFirst, Mode=OneWay}"
                        Command="{Binding SetRuntimeModeCommand}" CommandParameter="Codex"
                        Padding="10,6" HorizontalContentAlignment="Center" />
        </Grid>
      </Border>

      <Border Height="1" Background="#222226" Margin="0,10" />

      <!-- Open existing project. -->
      <TextBlock Text="Open existing" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                 LetterSpacing="1" />
      <Button Content="Open a project folder…" Command="{Binding OpenFolderCommand}"
              Padding="14,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
      <TextBlock Text="Recent" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0"
                 IsVisible="{Binding Recent.Count, Converter={x:Static conv:CountToBoolConverter.Instance}}" />
      <ItemsControl ItemsSource="{Binding Recent}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,1"
                    Background="#151528" BorderThickness="0"
                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
              <TextBlock Text="{Binding}" Foreground="#CCCCDD" FontSize="12" TextTrimming="CharacterEllipsis" />
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>

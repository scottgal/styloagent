<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:lucid="clr-namespace:Mostlylucid.LucidView.Markdown;assembly=Mostlylucid.LucidView.Markdown"
             x:Class="Styloagent.App.Views.MarkdownDocumentView"
             x:DataType="vm:MarkdownDocumentViewModel">

  <!-- A light "paper" document panel beside the dark terminals. The markdown text/inline
       elements inherit Foreground, which under the app's Dark theme is light — that rendered
       light-on-light here. Pin an explicit dark Foreground so the paper stays readable
       regardless of the app theme variant. -->
  <ScrollViewer Background="#FBFBFB" Padding="16,12">
    <lucid:LucidMarkdownView Markdown="{Binding Markdown}"
                             SourcePath="{Binding SourcePath}"
                             Foreground="#1A1A1A" />
  </ScrollViewer>

</UserControl>

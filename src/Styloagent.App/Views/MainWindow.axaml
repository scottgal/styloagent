<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
        xmlns:views="clr-namespace:Styloagent.App.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        x:Class="Styloagent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Styloagent Dock"
        Width="1200"
        Height="800">

  <DockPanel>

    <!-- Top cockpit bar — minimal chrome; extend here for future agent-detection dropdown -->
    <Border DockPanel.Dock="Top"
            Background="#1E1E2E"
            Padding="8,4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="➕ Add agent"
                Command="{Binding AddAgentCommand}"
                Padding="10,4"
                FontSize="13" />
      </StackPanel>
    </Border>

    <dock:DockControl x:Name="DockControl"
                      Layout="{Binding Layout}"
                      InitializeLayout="False"
                      InitializeFactory="False">
      <dock:DockControl.DataTemplates>
        <DataTemplate DataType="vm:AgentPaneViewModel">
          <views:AgentPaneView />
        </DataTemplate>
      </dock:DockControl.DataTemplates>
    </dock:DockControl>

  </DockPanel>

</Window>

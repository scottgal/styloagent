<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
        xmlns:views="clr-namespace:Styloagent.App.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        x:Class="Styloagent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Styloagent Dock"
        Width="1200"
        Height="800">

  <dock:DockControl x:Name="DockControl"
                    Layout="{Binding Layout}"
                    InitializeLayout="False"
                    InitializeFactory="False">
    <dock:DockControl.DataTemplates>
      <DataTemplate DataType="vm:AgentPaneViewModel">
        <views:AgentPaneView />
      </DataTemplate>
    </dock:DockControl.DataTemplates>
  </dock:DockControl>

</Window>

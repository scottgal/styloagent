<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Styloagent.App.ViewModels"
             xmlns:rag="using:Styloagent.Core.Retrieval"
             x:Class="Styloagent.App.Views.DocsChatView"
             x:DataType="vm:DocsChatViewModel">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBackgroundBrush}">
    <Border Padding="18,12" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
      <StackPanel Spacing="2"><TextBlock Text="Docs chat" FontWeight="SemiBold" FontSize="16"/><TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/></StackPanel>
    </Border>
    <ScrollViewer Grid.Row="1" Margin="18,14">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:DocsChatMessage">
          <Border MaxWidth="800" Margin="0,0,0,12" Padding="12,9" CornerRadius="8">
            <Border.Styles><Style Selector="Border"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/></Style></Border.Styles>
            <StackPanel Spacing="7"><TextBlock Text="{Binding Text}" TextWrapping="Wrap"/><ItemsControl ItemsSource="{Binding Sources}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="rag:ContextHit"><TextBlock Text="{Binding Title}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel>
          </Border>
        </DataTemplate></ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <Border Grid.Row="2" Padding="14" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"><TextBox Text="{Binding Draft}" Watermark="Ask about the docs…"/><Button Grid.Column="1" Command="{Binding SendCommand}" Content="Send"/></Grid>
    </Border>
  </Grid>
</UserControl>

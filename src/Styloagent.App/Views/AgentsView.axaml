<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:conv="clr-namespace:Styloagent.App.Converters"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             x:Class="Styloagent.App.Views.AgentsView"
             x:DataType="vm:MainWindowViewModel">

  <UserControl.Styles>
    <Style Selector="Border.needsYou">
      <Setter Property="BorderBrush" Value="#E5A05A" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <!-- One roster row. Extracted to a resource so it can be rendered on a single control in a
         screenshot test (a headless ItemsControl doesn't materialize its item containers). -->
    <DataTemplate x:Key="AgentRowTemplate" DataType="vm:AgentPaneViewModel">
      <Button HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              Background="Transparent"
              BorderThickness="0"
              Padding="0"
              Margin="0,1,0,0"
              Command="{Binding DataContext.SelectPaneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
              CommandParameter="{Binding}">
        <Border Background="{Binding RowHighlightHex}"
                BorderBrush="{Binding SelectionBrushHex}"
                BorderThickness="1"
                CornerRadius="2"
                Classes.needsYou="{Binding NeedsYou}"
                Margin="{Binding Depth, Converter={x:Static conv:DepthToMarginConverter.Instance}}">
          <Grid ColumnDefinitions="4,*,Auto">
            <!-- Per-agent identity colour (same as its terminal accent) -->
            <Border Grid.Column="0" Background="{Binding BorderColorHex}" Width="4" />
            <StackPanel Grid.Column="1" Margin="8,6" Spacing="2">
              <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                         Foreground="{Binding BorderColorHex}" />
              <!-- Live hook state (§4.4): glyph + label, coloured by state -->
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding HookStateGlyph}" FontSize="11"
                           Foreground="{Binding HookStateColorHex}" />
                <TextBlock Text="{Binding HookStateText}" FontSize="10"
                           Foreground="{Binding HookStateColorHex}" />
              </StackPanel>
            </StackPanel>
            <!-- Identity dot; amber when the agent needs you -->
            <Ellipse Grid.Column="2" Width="8" Height="8" Margin="0,0,10,0"
                     VerticalAlignment="Center" Fill="{Binding HookStateColorHex}" />
          </Grid>
        </Border>
      </Button>
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,6">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <ic:SymbolIcon Symbol="People" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
            <StackPanel>
              <TextBlock Text="Agents" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource AccentBrush}" LetterSpacing="1" />
              <TextBlock Text="{Binding FleetHudText}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                        IsVisible="{Binding WaitingCount, Converter={x:Static conv:CountToBoolConverter.Instance}}">
              <TextBlock Text="{Binding AttentionHudText}" FontSize="10" Foreground="{DynamicResource AttentionBrush}" VerticalAlignment="Center" />
              <Button Content="Jump ⌥→" FontSize="10" Padding="6,1" Command="{Binding JumpToNextWaitingCommand}" />
            </StackPanel>
            <ToggleButton VerticalAlignment="Center" FontSize="10" Padding="6,2"
                          IsChecked="{Binding FleetPaused, Mode=OneWay}" Command="{Binding PauseFleetCommand}"
                          Content="⏸ Pause" />
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- PROPOSED subsystems: written by the overview agent; click Spawn to promote to live. -->
          <StackPanel IsVisible="{Binding ProposedTeam.Proposals.Count, Converter={x:Static conv:CountToBoolConverter.Instance}}">
            <Border Background="#2A1A1A" Padding="8,4">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="PROPOSED" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AttentionBrush}" LetterSpacing="1" />
                <Button Grid.Column="1" Content="Spawn all" FontSize="10" Padding="6,1"
                        Command="{Binding ProposedTeam.SpawnAllCommand}" />
              </Grid>
            </Border>
            <ItemsControl ItemsSource="{Binding ProposedTeam.Proposals}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ProposedAgentItem">
                  <Border Background="{DynamicResource RowBgBrush}" Margin="0,1,0,0">
                    <Grid ColumnDefinitions="4,*,Auto">
                      <Border Grid.Column="0" Background="{Binding ColorHex}" Width="4" />
                      <StackPanel Grid.Column="1" Margin="8,5" Spacing="1">
                        <TextBlock Text="{Binding Prefix}" FontWeight="SemiBold" FontSize="12" Foreground="{Binding ColorHex}" />
                        <TextBlock Text="{Binding Responsibility}" FontSize="10" Foreground="#8888AA" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Button Grid.Column="2" Content="Spawn" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"
                              Command="{Binding DataContext.ProposedTeam.SpawnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding Agent}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Live roster -->
          <ItemsControl ItemsSource="{Binding Panes}"
                        ItemTemplate="{StaticResource AgentRowTemplate}" />

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>

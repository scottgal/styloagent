<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Styloagent.App.ViewModels"
             xmlns:views="clr-namespace:Styloagent.App.Views"
             xmlns:git="clr-namespace:Styloagent.Core.Git;assembly=Styloagent.Core"
             x:Class="Styloagent.App.Views.ChangesView"
             x:DataType="vm:ChangesViewModel">

  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

      <!-- ── Branch bar ─────────────────────────────────────────────────────── -->
      <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBgBrush}" Padding="6,4">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <!-- Current-branch label -->
          <TextBlock Grid.Column="0"
                     Text="Branch:"
                     FontSize="11"
                     Foreground="{DynamicResource MutedTextBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,4,0" />
          <!-- Branch switcher -->
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding Branches}"
                    SelectedItem="{Binding SelectedBranch}"
                    FontSize="11"
                    Padding="4,2"
                    x:Name="BranchComboBox">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="git:GitBranch">
                <TextBlock Text="{Binding Name}"
                           FontSize="11" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <!-- New branch text box -->
          <TextBox Grid.Column="2"
                   Text="{Binding NewBranchName}"
                   Watermark="new branch"
                   FontSize="11"
                   Padding="4,2"
                   Width="110"
                   Margin="6,0,0,0" />
          <!-- Create branch button -->
          <Button Grid.Column="3"
                  Content="+"
                  FontSize="11"
                  Padding="6,2"
                  Margin="4,0,0,0"
                  ToolTip.Tip="Create branch"
                  Command="{Binding CreateBranchCommand}" />
        </Grid>
      </Border>

      <!-- ── Unstaged section ──────────────────────────────────────────────── -->
      <Border Grid.Row="1" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,5">
        <TextBlock Text="Unstaged" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
      </Border>

      <ListBox Grid.Row="2"
               ItemsSource="{Binding UnstagedFiles}"
               SelectedItem="{Binding SelectedFile}"
               SelectionChanged="OnFileSelectionChanged"
               MaxHeight="120"
               Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               x:Name="UnstagedList">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="git:GitChange">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,2">
              <TextBlock Grid.Column="0" Text="{Binding Kind}"
                         FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center"
                         MinWidth="56" />
              <TextBlock Grid.Column="1" Text="{Binding Path}"
                         FontSize="11"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         FontFamily="Cascadia Mono,Consolas,monospace"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Button Grid.Column="2"
                      Content="Stage"
                      FontSize="10" Padding="6,1"
                      Margin="4,0,0,0"
                      Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- ── Staged section ───────────────────────────────────────────────── -->
      <Border Grid.Row="3" Background="{DynamicResource PanelHeaderBgBrush}" Padding="8,5" Margin="0,4,0,0">
        <TextBlock Text="Staged" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
      </Border>

      <ListBox Grid.Row="4"
               ItemsSource="{Binding StagedFiles}"
               SelectedItem="{Binding SelectedFile}"
               SelectionChanged="OnFileSelectionChanged"
               MaxHeight="120"
               Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               x:Name="StagedList">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="git:GitChange">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,2">
              <TextBlock Grid.Column="0" Text="{Binding Kind}"
                         FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center"
                         MinWidth="56" />
              <TextBlock Grid.Column="1" Text="{Binding Path}"
                         FontSize="11"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         FontFamily="Cascadia Mono,Consolas,monospace"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Button Grid.Column="2"
                      Content="Unstage"
                      FontSize="10" Padding="6,1"
                      Margin="4,0,0,0"
                      Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- ── Commit bar + push/pull/stash actions ─────────────────────────── -->
      <Grid Grid.Row="5" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Error banner -->
        <Border Grid.Row="0"
                IsVisible="{Binding HasWriteError}"
                Background="{DynamicResource AttentionBrush}"
                CornerRadius="3"
                Margin="6,6,6,0"
                Padding="8,5">
          <TextBlock Text="{Binding WriteError}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource PanelBgBrush}" />
        </Border>

        <!-- Commit bar -->
        <Border Grid.Row="1" Padding="6,6,6,0">
          <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding CommitMessage}"
                     Watermark="Commit message…"
                     AcceptsReturn="True"
                     MinHeight="54"
                     FontSize="11"
                     Padding="6,4"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <Button Grid.Column="1"
                    Content="Commit"
                    FontSize="11" Padding="8,4"
                    Margin="4,0,0,0"
                    VerticalAlignment="Stretch"
                    Command="{Binding CommitCommand}"
                    IsEnabled="{Binding CanCommit}" />
          </Grid>
        </Border>

        <!-- Push / Pull row -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="6"
                    Margin="6,4,6,0">
          <Button Content="Push"
                  FontSize="11" Padding="8,4"
                  Command="{Binding PushCommand}" />
          <Button Content="Pull"
                  FontSize="11" Padding="8,4"
                  Command="{Binding PullCommand}" />
        </StackPanel>

        <!-- Stash row -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" Margin="6,4,6,6">
          <Button Grid.Column="0"
                  Content="Stash"
                  FontSize="11" Padding="8,4"
                  Margin="0,0,4,0"
                  ToolTip.Tip="Stash working-tree changes"
                  Command="{Binding StashCommand}" />
          <Button Grid.Column="1"
                  Content="Pop"
                  FontSize="11" Padding="8,4"
                  Margin="0,0,6,0"
                  ToolTip.Tip="Pop the most recent stash"
                  Command="{Binding StashPopCommand}" />
          <TextBlock Grid.Column="2"
                     FontSize="10"
                     Foreground="{DynamicResource MutedTextBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0} stashed">
                <Binding Path="Stashes.Count" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </Grid>

        <!-- Diff panel -->
        <views:DiffView Grid.Row="4" DataContext="{Binding Diff}" />

      </Grid>

    </Grid>
  </Border>

</UserControl>
